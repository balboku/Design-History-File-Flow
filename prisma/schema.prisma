generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  PM
  RD
  QA
  ADMIN
}

enum ProjectPhase {
  Concept
  Planning
  DesignInput
  DesignOutput
  Verification
  Validation
  DesignTransfer
  PostMarket
}

enum DeliverableStatus {
  Draft
  InReview
  Released
  Locked
}

enum TaskStatus {
  Todo
  InProgress
  Done
}

enum ChangeRequestStatus {
  Draft
  Active
  Submitted
  InReview
  Approved
  Rejected
  Implemented
  Closed
}

enum ApprovalDecision {
  Approved
  Rejected
}

enum PendingItemStatus {
  Open
  Resolved
}

model User {
  id                        String                   @id @default(cuid())
  email                     String                   @unique
  name                      String
  role                      Role
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  assignedTasks             Task[]                   @relation("TaskAssignee")
  createdTasks              Task[]                   @relation("TaskCreator")
  ownedProjects             Project[]                @relation("ProjectOwner")
  qaOwnedDeliverables       DeliverablePlaceholder[] @relation("DeliverableOwner")
  uploadedRevisions         FileRevision[]           @relation("RevisionUploader")
  uploadedAttachments       Attachment[]             @relation("AttachmentUploader")
  requestedChanges          ChangeRequest[]          @relation("ChangeRequester")
  approvedChanges           ChangeRequest[]          @relation("ChangeApprover")
  triggeredPhaseTransitions PhaseTransition[]        @relation("PhaseTransitionTriggeredBy")
  approvals                 Approval[]               @relation("ApprovalActor")
  auditLogs                 AuditLog[]               @relation("AuditActor")
  approvedOverrides         OverrideDecision[]       @relation("OverrideApprover")
}

model Project {
  id               String                   @id @default(cuid())
  code             String                   @unique
  name             String
  description      String?
  currentPhase     ProjectPhase             @default(Concept)
  previousPhase    ProjectPhase?
  ownerId          String?
  targetEndDate    DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  owner            User?                    @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tasks            Task[]
  deliverables     DeliverablePlaceholder[]
  pendingItems     PendingItem[]
  phaseTransitions PhaseTransition[]
  changeRequests   ChangeRequest[]

  @@index([currentPhase])
  @@index([ownerId])
}

model PhaseTransition {
  id               String            @id @default(cuid())
  projectId        String
  fromPhase        ProjectPhase
  toPhase          ProjectPhase
  triggeredById    String?
  triggeredBy      User?             @relation("PhaseTransitionTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt        DateTime          @default(now())
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  overrideDecision OverrideDecision?

  @@index([projectId])
  @@index([triggeredById])
}

model OverrideDecision {
  id           String          @id @default(cuid())
  transitionId String          @unique
  approverId   String?
  rationale    String?
  createdAt    DateTime        @default(now())
  transition   PhaseTransition @relation(fields: [transitionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  approver     User?           @relation("OverrideApprover", fields: [approverId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  pendingItems PendingItem[]

  @@index([approverId])
}

model DeliverablePlaceholder {
  id                 String                     @id @default(cuid())
  projectId          String
  ownerId            String?
  code               String
  title              String
  description        String?
  phase              ProjectPhase
  isRequired         Boolean                    @default(true)
  status             DeliverableStatus          @default(Draft)
  targetDate         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  lockedAt           DateTime?
  project            Project                    @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  owner              User?                      @relation("DeliverableOwner", fields: [ownerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  taskLinks          TaskDeliverable[]
  fileRevisions      FileRevision[]
  approvals          Approval[]
  pendingItems       PendingItem[]
  changeRequestLinks ChangeRequestDeliverable[]

  @@unique([projectId, code])
  @@index([projectId, phase, status])
  @@index([ownerId])
}

model PendingItem {
  id               String                 @id @default(cuid())
  projectId        String
  deliverableId    String
  sourceOverrideId String?
  title            String
  detail           String?
  status           PendingItemStatus      @default(Open)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  resolvedAt       DateTime?
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deliverable      DeliverablePlaceholder @relation(fields: [deliverableId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sourceOverride   OverrideDecision?      @relation(fields: [sourceOverrideId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([projectId, deliverableId])
  @@index([projectId, status])
  @@index([deliverableId])
  @@index([sourceOverrideId])
}

/// Application invariant: every Task must have at least one TaskDeliverable row.
model Task {
  id               String            @id @default(cuid())
  projectId        String
  assigneeId       String?
  createdById      String?
  code             String
  title            String
  description      String?
  plannedPhase     ProjectPhase
  status           TaskStatus        @default(Todo)
  plannedStartDate DateTime?
  targetDate       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignee         User?             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy        User?             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deliverableLinks TaskDeliverable[]
  attachments      Attachment[]

  @@unique([projectId, code])
  @@index([projectId, plannedPhase, status])
  @@index([assigneeId])
  @@index([createdById])
}

model TaskDeliverable {
  id            String                 @id @default(cuid())
  taskId        String
  deliverableId String
  createdAt     DateTime               @default(now())
  task          Task                   @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deliverable   DeliverablePlaceholder @relation(fields: [deliverableId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([taskId, deliverableId])
  @@index([deliverableId])
}

model FileRevision {
  id              String                 @id @default(cuid())
  deliverableId   String
  changeRequestId String?
  uploadedById    String?
  revisionNumber  Int
  fileName        String
  storagePath     String
  mimeType        String?
  fileSizeBytes   Int?
  changeSummary   String?
  createdAt       DateTime               @default(now())
  deliverable     DeliverablePlaceholder @relation(fields: [deliverableId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  changeRequest   ChangeRequest?         @relation(fields: [changeRequestId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  uploadedBy      User?                  @relation("RevisionUploader", fields: [uploadedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  approvals       Approval[]

  @@unique([deliverableId, revisionNumber])
  @@index([changeRequestId])
  @@index([uploadedById])
  @@index([createdAt])
}

model PartComponent {
  id             String                       @id @default(cuid())
  partNumber     String                       @unique
  name           String
  description    String?
  manufacturer   String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  changeRequests ChangeRequestPartComponent[]

  @@index([name])
}

/**
 * Tags a DeliverablePlaceholder to a ChangeRequest. One CR can tag many deliverables.
 */
model ChangeRequestDeliverable {
  id              String                 @id @default(cuid())
  changeRequestId String
  deliverableId   String
  createdAt       DateTime               @default(now())
  changeRequest   ChangeRequest          @relation(fields: [changeRequestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  deliverable     DeliverablePlaceholder @relation(fields: [deliverableId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([changeRequestId, deliverableId])
  @@index([deliverableId])
}

/**
 * Tags a PartComponent to a ChangeRequest. One CR can tag many part numbers.
 */
model ChangeRequestPartComponent {
  id              String        @id @default(cuid())
  changeRequestId String
  partComponentId String
  createdAt       DateTime      @default(now())
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  partComponent   PartComponent @relation(fields: [partComponentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([changeRequestId, partComponentId])
  @@index([partComponentId])
}

model ChangeRequest {
  id               String                       @id @default(cuid())
  projectId        String?
  code             String                       @unique
  title            String
  description      String?
  status           ChangeRequestStatus          @default(Draft)
  requesterId      String?
  approverId       String?
  submittedAt      DateTime?
  approvedAt       DateTime?
  implementedAt    DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  project          Project?                     @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  requester        User?                        @relation("ChangeRequester", fields: [requesterId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  approver         User?                        @relation("ChangeApprover", fields: [approverId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  impactAnalysis   ImpactAnalysis?
  deliverableLinks ChangeRequestDeliverable[]
  partLinks        ChangeRequestPartComponent[]
  fileRevisions    FileRevision[]

  @@index([status])
  @@index([projectId])
  @@index([requesterId])
  @@index([approverId])
}

model ImpactAnalysis {
  id                  String        @id @default(cuid())
  changeRequestId     String        @unique
  summary             String
  regulatoryImpact    String?
  productRiskImpact   String?
  verificationImpact  String?
  validationImpact    String?
  manufacturingImpact String?
  documentationImpact String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  changeRequest       ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Approval {
  id             String                 @id @default(cuid())
  deliverableId  String
  fileRevisionId String?
  actorId        String?
  decision       ApprovalDecision
  comment        String?
  createdAt      DateTime               @default(now())
  deliverable    DeliverablePlaceholder @relation(fields: [deliverableId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fileRevision   FileRevision?          @relation(fields: [fileRevisionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  actor          User?                  @relation("ApprovalActor", fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([deliverableId, createdAt])
  @@index([fileRevisionId])
  @@index([actorId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  actorId    String?
  detail     String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([action])
}

/// Reference attachments for tasks (non-compliance files)
model Attachment {
  id            String   @id @default(cuid())
  taskId        String
  fileName      String
  storagePath   String
  mimeType      String?
  fileSizeBytes Int?
  uploadedById  String?
  createdAt     DateTime @default(now())
  task           Task    @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploader      User?    @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([taskId])
  @@index([uploadedById])
  @@index([createdAt])
}
